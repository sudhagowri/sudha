#include <stdio.h>
void printBinary(int n) 
{
    int binaryNum[32];
    int i=0;
    while (n>0) 
    {
        binaryNum[i] = n%2;
        n=n/2;
        i++;
    }
    for (int j=i-1;j>=0;j--) 
    {
        printf("%d",binaryNum[j]);
    }
}
int main() 
{
    int num;
    printf("Enter a number: ");
    scanf("%d",&num);
    printf("Binary representation of %d is:",num);
    printBinary(num);
    printf("\n");
    return 0;
}